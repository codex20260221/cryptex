{
    "name": "michaelmawhinney/cryptex",
    "description": "A simple PHP class for 2-way authenticated encryption using XChaCha20 + Poly1305 (libsodium)",
    "keywords": ["encryption", "decryption", "libsodium", "xchacha20", "poly1305", "argon2"],
    "homepage": "https://github.com/michaelmawhinney/cryptex",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Mawhinney",
            "homepage": "https://michaelmawhinney.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-sodium": "*"
    },
    "autoload": {
        "psr-4": {
            "cryptex\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php -l src/Cryptex.php && php -l tests/CryptexTest.php",
        "stan": "phpstan analyse --level=max --ansi",
        "cs-check": "php-cs-fixer fix --dry-run --diff --ansi",
        "cs-fix": "php-cs-fixer fix --diff --ansi"
    }
}
